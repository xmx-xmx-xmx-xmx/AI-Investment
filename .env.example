# ===================================
# AI 量化投资系统 —— 环境变量配置（模板）
# 复制此文件为 .env 并填入真实配置
# .env 已在 .gitignore 中，不会被推送到 GitHub
# ===================================

# ── 大模型（硅基流动，必填） ──
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ── 飞书多维表格（必填） ──
# 从飞书开放平台获取：https://open.feishu.cn/app
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
# Base Token 从多维表格 URL 获取：https://xxx.feishu.cn/base/{这个}
FEISHU_BITABLE_TOKEN=your_bitable_token
# 交易流水表 ID
FEISHU_TABLE_ID=tbl_your_table_id
# 底仓表 ID
FEISHU_POSITIONS_TABLE_ID=tbl_your_positions_table_id

# ── 飞书群机器人 Webhook（日报/简报推送，必填） ──
# 在飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
# 如果开启了签名校验，填密钥；没开则留空
FEISHU_WEBHOOK_SECRET=your_webhook_secret

# ── Tavily 搜索 API（新闻抓取，可选但建议配置） ──
# 免费注册：https://tavily.com/，每月 1000 次
TAVILY_API_KEY=tvly-dev-your-tavily-key

# ── 系统配置 ──
LOG_LEVEL=INFO
